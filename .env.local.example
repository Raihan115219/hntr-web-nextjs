# Copy this file to .env.local and fill in real values.

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sepolia RPC used for read calls from the browser (approve/allowance/balance)
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Must match the HNTRMembership deployment address used by the backend
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Must match the USDT/USDC addresses passed into the HNTRMembership constructor
NEXT_PUBLIC_USDT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Public URL of this app, shown in the ConnectKit wallet-connect modal
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Free project id from https://cloud.reown.com (WalletConnect Cloud) - powers the
# WalletConnect connector (mobile wallet QR pairing) inside the ConnectKit modal.
# Injected wallets (MetaMask, Rabby, Coinbase extension, etc.) work fine without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
